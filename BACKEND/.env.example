# NEXURA Scanner — Environment Configuration
# Copy this file to .env and fill in your values

# AI Model
# NEXURA_MODEL=gguf_models/Qwen2.5-7B-Instruct.Q4_K_M.gguf
# NEXURA_CTX_SIZE=4096
# NEXURA_THREADS=4
# NEXURA_GPU_LAYERS=0
# NEXURA_TEMP=0.1
# NEXURA_MAX_TOKENS=2048

# Web Server
# NEXURA_WEB_HOST=0.0.0.0
# NEXURA_WEB_PORT=8080
# NEXURA_API_KEY=

# Scanner
# NEXURA_TIMEOUT=300
# NEXURA_SOCKET_TIMEOUT=2.0
# NEXURA_SSL_VERIFY=1
# NEXURA_SCANNER_WORKERS=4
